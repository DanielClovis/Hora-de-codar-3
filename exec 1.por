programa
{
    funcao inicio()
    {
        inteiro contador

        // começa a contagem em 30
        para (contador = 30; contador >= 0; contador--)
        {
            // mostra o número atual da contagem
            escreva(contador, "\n")
        }

        // quando terminar a contagem aparece a mensagem
        escreva("EXPLOSAO")
    }
}